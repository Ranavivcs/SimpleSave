# SimpleSave — environment template.
# ──────────────────────────────────────────────────────────────────────────
# SETUP (do this BEFORE running anything, on every machine):
#   1. Copy this file to `.env.local`  →  `cp .env.example .env.local`
#   2. Fill the blanks below with the TEAM's shared Supabase values
#      (ask a teammate / the Supabase dashboard → Project Settings → API & Database).
#   3. `.env.local` is gitignored and must STAY that way — never commit real keys (Privacy Law Std 13).
# Everyone on the team uses the SAME shared Supabase project, so the values are identical for all of us.
# ──────────────────────────────────────────────────────────────────────────

# --- Supabase project (shared, EU / eu-central-1) ---
NEXT_PUBLIC_SUPABASE_URL=https://iknokcilvdzbmevxhisy.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # public anon JWT  (dashboard → API)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_… key (dashboard → API)
SUPABASE_SERVICE_ROLE_KEY=              # SECRET service_role JWT — never expose client-side

# --- App public URL (for Supabase email/magic-link redirects) ---
# Optional in dev: if unset, the app derives its own origin from the request, so
# magic links return to whatever port `next dev` used (pinned to 3001 — see
# package.json). Set this explicitly in production.
# NEXT_PUBLIC_SITE_URL=http://localhost:3001

# --- Database (Supabase pooler; host = aws-1-eu-central-1, user = postgres.<project-ref>) ---
# Replace <DB_PASSWORD> with the shared database password. Keep the rest as-is.
# Pooled (transaction, 6543) — app runtime via @prisma/adapter-pg:
DATABASE_URL=postgresql://postgres.iknokcilvdzbmevxhisy:<DB_PASSWORD>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Session pooler (5432) — Prisma CLI (db push / migrate):
DIRECT_URL=postgresql://postgres.iknokcilvdzbmevxhisy:<DB_PASSWORD>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres
